# ─────────────────────────────────────────────────────────────
# NearPrice API 환경변수 템플릿
# 복사 후 .env 로 저장:  cp .env.example .env
#
# [필수] 표시된 항목은 반드시 실제 값으로 교체해야 서버가 시작됩니다.
# [선택] 표시된 항목은 없으면 해당 기능이 비활성화됩니다 (로컬 개발용).
# ─────────────────────────────────────────────────────────────

NODE_ENV=development   # development | production

# ─── Database [필수] ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DATABASE=nearprice

# ─── App ─────────────────────────────────────────────────────
PORT=3000

# ─── JWT [필수] ───────────────────────────────────────────────
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Kakao OAuth [필수] ───────────────────────────────────────
KAKAO_API_URL=https://kapi.kakao.com
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# ─── Admin [필수] ─────────────────────────────────────────────
# 해시 생성: node scripts/generate-admin-hash.mjs <password>
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=your_generated_hash

# ─── CORS ────────────────────────────────────────────────────
# 프로덕션: 정확한 도메인 지정 (https://nearprice.kr)
# 로컬: 프론트 개발 서버 주소
CORS_ORIGIN=http://localhost:5173

# ─── AWS S3 이미지 업로드 [프로덕션 필수] ─────────────────────
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-s3-bucket-name   # terraform output 에서 확인

# ─── Upload Storage (로컬/프로덕트 분리) ───────────────────────
# 개발 기본값: local (S3 없어도 등록 가능)
# 프로덕션: NODE_ENV=production이면 항상 S3 강제
# UPLOAD_STORAGE=local | s3
# UPLOAD_STORAGE=local
# LOCAL_UPLOAD_DIR=./uploads
# UPLOAD_PUBLIC_BASE_URL=http://localhost:3000

# ─── Naver Maps API (NCP) [선택 — 없으면 지도/검색 기능 비활성화] ──
NAVER_MAP_CLIENT_ID=your_ncp_client_id
NAVER_MAP_CLIENT_SECRET=your_ncp_client_secret

# ─── Naver Search API [선택 — 없으면 매장 검색 기능 비활성화] ──────
NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id
NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret

# ─── Vworld Geocoder API [선택 — 없으면 역지오코딩 비활성화] ─────────
VWORLD_API_KEY=your_vworld_api_key

# ─── Firebase Admin SDK (FCM 푸시) [선택] ────────────────────
# 전체 service account JSON을 한 줄로 붙여넣기
# 생성: Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id",...}

# ─── Redis [선택 — 없으면 리프레시 토큰 무효화 비활성화] ────────
# 로컬: redis://localhost:6379
# 프로덕션: redis://your-redis-host:6379
REDIS_URL=redis://localhost:6379

# ─── Sentry 에러 추적 [선택] ─────────────────────────────────
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
