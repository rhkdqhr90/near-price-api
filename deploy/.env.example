# NearPrice API - 프로덕션 환경 변수 예시
# 사용법: .env.example을 .env.production으로 복사하고 값을 수정하세요

# 환경 설정
NODE_ENV=production

# === DATABASE (PostgreSQL) ===
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=nearprice_user
DB_PASSWORD=your-very-strong-password-here
DB_DATABASE=near_price
# 프로덕션에서는 반드시 SSL 연결 사용
DB_SSL=true

# === REDIS (캐싱, Rate Limiting, 세션) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-strong-password-here
REDIS_DB=0

# === JWT 토큰 설정 ===
# 새로 생성: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-base64-encoded-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# === 애플리케이션 설정 ===
PORT=3000
CORS_ORIGIN=https://app.nearprice.com,https://admin.nearprice.com
BASE_URL=https://api.nearprice.com

# === Kakao OAuth ===
KAKAO_REST_API_KEY=your-production-kakao-rest-api-key-here
KAKAO_API_URL=https://kapi.kakao.com

# === 관리자 계정 (임시: OAuth로 대체 권장) ===
# node scripts/generate-admin-hash.mjs <new-password>로 새로 생성
ADMIN_EMAIL=admin@nearprice.com
ADMIN_PASSWORD_HASH=salt:hex-hash-string-here

# === Elasticsearch 검색 ===
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_INDEX=products

# === 모니터링 (선택사항) ===
# Sentry 에러 추적
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic 모니터링
# NEW_RELIC_LICENSE_KEY=your-new-relic-key-here
# NEW_RELIC_APP_NAME=NearPrice-API

# === AWS S3 (파일 업로드 - 선택사항) ===
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-key-here
# AWS_S3_BUCKET=nearprice-uploads
# AWS_S3_URL=https://nearprice-uploads.s3.amazonaws.com

# === 이메일 설정 (선택사항) ===
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=noreply@nearprice.com
# MAIL_PASSWORD=your-app-password-here

# === 로깅 설정 (선택사항) ===
# LOG_LEVEL=warn
# LOG_DIR=./logs

# === 백업 설정 (선택사항) ===
# BACKUP_SCHEDULE=0 2 * * * (매일 새벽 2시)
# BACKUP_RETENTION_DAYS=30
